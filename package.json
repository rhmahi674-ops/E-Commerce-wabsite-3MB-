{
  "name": "ecommerce-neon",
  "version": "1.0.0",
  "description": "Simple E-Commerce website with Neon PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
